# OCM Report Management System — backend (.env is gitignored; copy to .env)

# Server
PORT=3000
HOST=127.0.0.1

# JWT (backend uses these to sign & verify tokens)
JWT_SECRET=change_me_in_production
# Leave JWT_EXPIRES_IN unset (or set to "none") for no expiry; or set e.g. 8h, 7d to expire
# JWT_EXPIRES_IN=8h
RESET_TOKEN_EXPIRES_IN=1h

# Optional: paste the token you get from login/register here (for Postman/scripts).
# Use as Authorization: Bearer ${ADMIN_TOKEN}
# ADMIN_TOKEN=eyJhbGciOiJIUzI1NiIs...

# Admin seed (created automatically on first run if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Optional: email for password reset (used for seed admin and backfill)
ADMIN_EMAIL=

# Upload settings
MAX_IMAGE_MB=5

# Email (Nodemailer SMTP – for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your-email@gmail.com

# Database (default in code: MySQL database name ocm_report_system)
# DB_DRIVER=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=ocm_report_system
# For local JSON store instead of MySQL:
# DB_DRIVER=file
